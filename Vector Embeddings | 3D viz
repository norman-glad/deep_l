    "import gensim.downloader as api\n",
    "from sklearn.manifold import TSNE\n",
    "import numpy as np\n",
    "import plotly.graph_objects as go\n",
    "from sklearn.metrics.pairwise import cosine_similarity\n",
    "\n",
    "model = api.load(\"glove-wiki-gigaword-50\")\n",
    "\n",
    "# words to viz \n",
    "words = ['tower', 'building', 'skyscraper', 'house', 'city', 'bridge', 'castle']\n",
    "vectors = np.array([model[word] for word in words])\n",
    "\n",
    "# dimensionality reduction (50D -> 3D)\n",
    "tsne = TSNE(n_components=3, perplexity=5, random_state=42)\n",
    "vectors_3d = tsne.fit_transform(vectors)\n",
    "\n",
    "# --- vector arrows (origin to point) \n",
    "origin = np.zeros(vectors_3d.shape)\n",
    "\n",
    "# --- dist viz\n",
    "# cosine similarity on the original high-dim vectors\n",
    "similarity_matrix = cosine_similarity(vectors)\n",
    "\n",
    "x_lines, y_lines, z_lines = [], [], []\n",
    "line_text = [] # To hold similarity scores\n",
    "\n",
    "# connect all points\n",
    "n_words = len(words)\n",
    "for i in range(n_words):\n",
    "    for j in range(i + 1, n_words):\n",
    "        # line from A -> B \n",
    "        x_lines += [vectors_3d[i, 0], vectors_3d[j, 0], None]\n",
    "        y_lines += [vectors_3d[i, 1], vectors_3d[j, 1], None]\n",
    "        z_lines += [vectors_3d[i, 2], vectors_3d[j, 2], None]\n",
    "        \n",
    "        # similarity score (label)\n",
    "        sim_score = similarity_matrix[i, j]\n",
    "        line_text.append(f\"{words[i]}-{words[j]}: {sim_score:.2f}\")\n",
    "\n",
    "fig = go.Figure()\n",
    "\n",
    "# Vector Arrows : Lines from Origin to word\n",
    "for i, word in enumerate(words):\n",
    "    fig.add_trace(go.Scatter3d(\n",
    "        x=[0, vectors_3d[i, 0]],\n",
    "        y=[0, vectors_3d[i, 1]],\n",
    "        z=[0, vectors_3d[i, 2]],\n",
    "        mode='lines',\n",
    "        line=dict(color='gray', width=4, dash='dot'),\n",
    "        showlegend=False,\n",
    "        hoverinfo='none',\n",
    "        name=f'Vector: {word}'\n",
    "    ))\n",
    "\n",
    "# Distance Lines \n",
    "fig.add_trace(go.Scatter3d(\n",
    "    x=x_lines,\n",
    "    y=y_lines,\n",
    "    z=z_lines,\n",
    "    mode='lines',\n",
    "    line=dict(color='lightblue', width=1),\n",
    "    hovertext=[f\"Similarity: {s}\" for s in line_text] * 2, \n",
    "    hoverinfo='text',\n",
    "    showlegend=False,\n",
    "    name='Distances'\n",
    "))\n",
    "\n",
    "# Words as points \n",
    "fig.add_trace(go.Scatter3d(\n",
    "    x=vectors_3d[:, 0],\n",
    "    y=vectors_3d[:, 1],\n",
    "    z=vectors_3d[:, 2],\n",
    "    mode='markers+text',\n",
    "    text=words,\n",
    "    textposition='top center',\n",
    "    marker=dict(size=8, color='red', line=dict(width=1, color='black')),\n",
    "    hoverinfo='text',\n",
    "    name='Words'\n",
    "))\n",
    "\n",
    "fig.update_layout(\n",
    "    title=\"Interactive 3D Word Embeddings (t-SNE)\",\n",
    "    scene=dict(\n",
    "        xaxis_title='Dimension x',\n",
    "        yaxis_title='Dimension y',\n",
    "        zaxis_title='Dimension z',\n",
    "        bgcolor='white'\n",
    "    ),\n",
    "    margin=dict(l=0, r=0, b=0, t=50), \n",
    "    legend=dict(x=0.1, y=0.9)\n",
    ")\n",
    "\n",
    "fig.show()"
   ]
  }
