extposition='top center',\n    marker=dict(size=8, color='red', line=dict(width=1, color='black')),\n    hoverinfo='text',\n    name='Words'\n))\n\nfig.update_layout(\n    title=\"Interactive 3D Word Embeddings (t-SNE)\",\n    scene=dict(\n        xaxis_title='Dimension x',\n        yaxis_title='Dimension y',\n        zaxis_title='Dimension z',\n        bgcolor='white'\n    ),\n    margin=dict(l=0, r=0, b=0, t=50), \n    legend=dict(x=0.1, y=0.9)\n)\n\nfig.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T04:23:25.668466Z","iopub.execute_input":"2026-03-30T04:23:25.669020Z","iopub.status.idle":"2026-03-30T04:23:52.503978Z","shell.execute_reply.started":"2026-03-30T04:23:25.668981Z","shell.execute_reply":"2026-03-30T04:23:52.502911Z"}},"outputs":[],"execution_count":null}]}