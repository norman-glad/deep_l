    "import gensim.downloader as api\n",
    "from sklearn.manifold import TSNE\n",
    "import matplotlib.pyplot as plt\n",
    "from mpl_toolkits.mplot3d import Axes3D\n",
    "import numpy as np\n",
    "\n",
    "model = api.load(\"glove-wiki-gigaword-50\")\n",
    "\n",
    "# Words to viz\n",
    "words = ['tower', 'building', 'skyscraper', 'house', 'city', 'bridge', 'castle']\n",
    "vectors = np.array([model[word] for word in words])\n",
    "\n",
    "# reduce dimensionality (50D -> 3D)\n",
    "tsne = TSNE(n_components=3, perplexity=5, random_state=42)\n",
    "vectors_3d = tsne.fit_transform(vectors)\n",
    "\n",
    "# 3D plot \n",
    "fig = plt.figure(figsize=(10, 8))\n",
    "ax = fig.add_subplot(111, projection='3d')\n",
    "ax.scatter(vectors_3d[:, 0], vectors_3d[:, 1], vectors_3d[:, 2])\n",
    "\n",
    "# mark points\n",
    "for i, word in enumerate(words):\n",
    "    ax.text(vectors_3d[i, 0], vectors_3d[i, 1], vectors_3d[i, 2], word)\n",
    "\n",
    "plt.title(\"3D Visualization of Word Embeddings using t-SNE\")\n",
    "plt.show()   "
   ]
