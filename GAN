    "import tensorflow as tf\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import time\n",
    "\n",
    "# Load Fashion MNIST data\n",
    "(train_images, train_labels), (test_images, test_labels) = tf.keras.datasets.fashion_mnist.load_data()\n",
    "\n",
    "# Store data in dictionaries as per instructions\n",
    "# ds1_norman: First 60,000 samples\n",
    "ds1_norman = {\n",
    "    'images': train_images,\n",
    "    'labels': train_labels\n",
    "}\n",
    "\n",
    "# ds2_norman: Next 10,000 samples\n",
    "ds2_norman = {\n",
    "    'images': test_images,\n",
    "    'labels': test_labels\n",
    "}\n",
    "\n",
    "# Normalize pixel values to range [-1, 1]\n",
    "ds1_norman['images'] = (ds1_norman['images'].astype('float32') - 127.5) / 127.5\n",
    "ds2_norman['images'] = (ds2_norman['images'].astype('float32') - 127.5) / 127.5\n",
    "\n",
    "# Display shapes\n",
    "print(\"Shape of ds1_norman['images']:\", ds1_norman['images'].shape)\n",
    "print(\"Shape of ds2_norman['images']:\", ds2_norman['images'].shape)"
   ]
