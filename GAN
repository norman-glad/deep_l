    "@tf.function\n",
    "def training_step(images):\n",
    "    noise = tf.random.normal([BATCH_SIZE, 100])\n",
    "\n",
    "    with tf.GradientTape() as gen_tape, tf.GradientTape() as disc_tape:\n",
    "        generated_images = generator_model_norman(noise, training=True)\n",
    "\n",
    "        real_output = discriminator_model_norman(images, training=True)\n",
    "        fake_output = discriminator_model_norman(generated_images, training=True)\n",
    "\n",
    "        gen_loss = cross_entropy_norman(tf.ones_like(fake_output), fake_output)\n",
    "        disc_loss = cross_entropy_norman(tf.ones_like(real_output), real_output) + \\\n",
    "                    cross_entropy_norman(tf.zeros_like(fake_output), fake_output)\n",
    "\n",
    "    gradients_of_generator = gen_tape.gradient(gen_loss, generator_model_norman.trainable_variables)\n",
    "    gradients_of_discriminator = disc_tape.gradient(disc_loss, discriminator_model_norman.trainable_variables)\n",
    "\n",
    "    generator_optimizer_norman.apply_gradients(zip(gradients_of_generator, generator_model_norman.trainable_variables))\n",
    "    discriminator_optimizer_norman.apply_gradients(zip(gradients_of_discriminator, discriminator_model_norman.trainable_variables))"
   ]
