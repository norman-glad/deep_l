    "def build_generator():\n",
    "    model = tf.keras.Sequential(name='generator_model_norman')\n",
    "    \n",
    "    # Input = Vector dim 100\n",
    "    # 1st Layer: Fully connected, 7*7*256 neurons, no bias\n",
    "    model.add(tf.keras.layers.Dense(7*7*256, use_bias=False, input_shape=(100,)))\n",
    "    \n",
    "    # 2nd Layer: Batch Normalization\n",
    "    model.add(tf.keras.layers.BatchNormalization())\n",
    "    \n",
    "    # 3rd Layer: Leaky ReLU\n",
    "    model.add(tf.keras.layers.LeakyReLU())\n",
    "    \n",
    "    # Reshape to (7, 7, 256) - Required before Transposed Conv\n",
    "    model.add(tf.keras.layers.Reshape((7, 7, 256)))\n",
    "    \n",
    "    # 4th Layer: Transposed Conv, 128 kernels, 5x5, stride 1, no bias, same padding\n",
    "    model.add(tf.keras.layers.Conv2DTranspose(128, (5, 5), strides=(1, 1), padding='same', use_bias=False))\n",
    "    \n",
    "    # 5th Layer: Batch Normalization\n",
    "    model.add(tf.keras.layers.BatchNormalization())\n",
    "    \n",
    "    # 6th Layer: Leaky ReLU\n",
    "    model.add(tf.keras.layers.LeakyReLU())\n",
    "    \n",
    "    # 7th Layer: Transposed Conv, 64 kernels, 5x5, stride 2, no bias, same padding\n",
    "    model.add(tf.keras.layers.Conv2DTranspose(64, (5, 5), strides=(2, 2), padding='same', use_bias=False))\n",
    "    \n",
    "    # 8th Layer: Batch Normalization\n",
    "    model.add(tf.keras.layers.BatchNormalization())\n",
    "    \n",
    "    # 9th Layer: Leaky ReLU\n",
    "    model.add(tf.keras.layers.LeakyReLU())\n",
    "    \n",
    "    # 10th Layer: Transposed Conv, 1 kernel, 5x5, stride 2, no bias, same padding, tanh activation\n",
    "    model.add(tf.keras.layers.Conv2DTranspose(1, (5, 5), strides=(2, 2), padding='same', use_bias=False, activation='tanh'))\n",
    "    \n",
    "    return model\n",
    "\n",
    "generator_model_norman = build_generator()\n",
    "generator_model_norman.summary()\n",
