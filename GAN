    "# Filter for pants (class label 1)\n",
    "# Use boolean masking to select images where labels are 1\n",
    "pants_ds1 = ds1_norman['images'][ds1_norman['labels'] == 1]\n",
    "pants_ds2 = ds2_norman['images'][ds2_norman['labels'] == 1]\n",
    "\n",
    "# Concatenate to create dataset_norman\n",
    "dataset_norman = np.concatenate((pants_ds1, pants_ds2), axis=0)\n",
    "\n",
    "# Expand dimensions to add channel dimension (28, 28, 1) for CNN input\n",
    "dataset_norman = np.expand_dims(dataset_norman, axis=-1)\n",
    "\n",
    "# Display shape (should be 7000 images)\n",
    "print(\"Shape of dataset_norman:\", dataset_norman.shape)\n",
    "\n",
    "# Plot the first 12 images\n",
    "plt.figure(figsize=(8, 8))\n",
    "for i in range(12):\n",
    "    plt.subplot(4, 3, i+1)\n",
    "    # Squeeze to remove channel dim for plotting\n",
    "    plt.imshow(dataset_norman[i].squeeze(), cmap='gray')\n",
    "    plt.xticks([])\n",
    "    plt.yticks([])\n",
    "plt.show()\n",
    "\n",
    "# Create training dataset\n",
    "BUFFER_SIZE = 7000\n",
    "BATCH_SIZE = 256\n",
    "\n",
    "train_dataset_norman = tf.data.Dataset.from_tensor_slices(dataset_norman).shuffle(BUFFER_SIZE).batch(BATCH_SIZE)"
