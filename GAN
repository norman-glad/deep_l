    "def build_discriminator():\n",
    "    model = tf.keras.Sequential(name='discriminator_model_norman')\n",
    "    \n",
    "    # Input = Image (28, 28, 1)\n",
    "    \n",
    "    # 1st Layer: Conv2D, 64 filters, 5x5, stride 2, same padding\n",
    "    model.add(tf.keras.layers.Conv2D(64, (5, 5), strides=(2, 2), padding='same', input_shape=[28, 28, 1]))\n",
    "    \n",
    "    # 2nd Layer: Leaky ReLU\n",
    "    model.add(tf.keras.layers.LeakyReLU())\n",
    "    \n",
    "    # 3rd Layer: Dropout 0.3\n",
    "    model.add(tf.keras.layers.Dropout(0.3))\n",
    "    \n",
    "    # 4th Layer: Conv2D, 128 filters, 5x5, stride 2, same padding\n",
    "    model.add(tf.keras.layers.Conv2D(128, (5, 5), strides=(2, 2), padding='same'))\n",
    "    \n",
    "    # 5th Layer: Leaky ReLU\n",
    "    model.add(tf.keras.layers.LeakyReLU())\n",
    "    \n",
    "    # 6th Layer: Dropout 0.3\n",
    "    model.add(tf.keras.layers.Dropout(0.3))\n",
    "    \n",
    "    # Flatten before Output\n",
    "    model.add(tf.keras.layers.Flatten())\n",
    "    \n",
    "    # Output Layer: Dense 1\n",
    "    model.add(tf.keras.layers.Dense(1))\n",
    "    \n",
    "    return model\n",
    "\n",
    "discriminator_model_norman = build_discriminator()\n",
    "discriminator_model_norman.summary()\n",
    "\n",
    "# Diagram for report\n",
    "tf.keras.utils.plot_model(discriminator_model_norman, to_file='discriminator_architecture.png', show_shapes=True, show_layer_names=True)"
   ]
