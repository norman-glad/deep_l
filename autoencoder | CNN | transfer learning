puts":[],"execution_count":null},{"cell_type":"code","source":"# Build and pretrain Autoencoder\n\ninputs_norman = tf.keras.Input(shape=(28,28,1), name='input')\n# Encoder\ne1 = tf.keras.layers.Conv2D(16, (3,3), strides=2, padding='same', activation='relu', name='enc_conv1')(inputs_norman)\ne2 = tf.keras.layers.Conv2D(8, (3,3), strides=2, padding='same', activation='relu', name='enc_conv2')(e1)\n# Decoder\nd1 = tf.keras.layers.Conv2DTranspose(8, (3,3), strides=2, padding='same', activation='relu', name='dec_convT1')(e2)\nd2 = tf.keras.layers.Conv2DTranspose(16, (3,3), strides=2, padding='same', activation='relu', name='dec_convT2')(d1)\noutputs = tf.keras.layers.Conv2D(1, (3,3), padding='same', activation='sigmoid', name='output')(d2)\n\nautoencoder_norman = tf.keras.Model(inputs=inputs_norman, outputs=outputs, name='Autoencoder')\n\nautoencoder_norman.compile(optimizer='adam', loss='mse')\n\nprint(\"\\n--- Autoencoder Model Summary ---\")\nautoencoder_norman.summary()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-10T02:35:23.064033Z","iopub.execute_input":"2026-03-10T02:35:23.064871Z","iopub.status.idle":"2026-03-10T02:35:23.129396Z","shell.execute_reply.started":"2026-03-10T02:35:23.064829Z","shell.execute_reply":"2026-03-10T02:35:23.128749Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"print(\"\\nTraining Autoencoder...\")\nautoencoder_history = autoencoder_norman.fit(\n    x_train_noisy_norman, unsupervised_train_norman,\n    validation_data=(x_val_noisy_norman, unsupervised_val_norman),\n    epochs=10,\n    batch_size=256,\n    shuffle=True,\n    verbose=1\n)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-10T02:36:09.530854Z","iopub.execute_input":"2026-03-10T02:36:09.531573Z","iopub.status.idle":"2026-03-10T02:36:24.870600Z","shell.execute_reply.started":"2026-03-10T02:36:09.531543Z","shell.execute_reply":"2026-03-10T02:36:24.869925Z"}},"outputs":[],"execution_count":null},{"cell_type":"cod