{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[],"dockerImageVersionId":31287,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"# Kaggle Inference with Hugging Face \n\n### **Objective:**\n1. Take a pretrained OCR model from Hugging Face\n2. Run the model for image-to-text (OCR text extraction)\n3. Check how the weights are stored","metadata":{}},{"cell_type":"code","source":"!pip install -q transformers Pillow requests\n\nimport torch\nfrom transformers import TrOCRProcessor, VisionEncoderDecoderModel\nfrom PIL import Image\nimport requests\nfrom io import BytesIO\nimport time","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-16T19:36:59.349207Z","iopub.execute_input":"2026-03-16T19:36:59.350046Z","iopub.status.idle":"2026-03-16T19:37:25.445546Z","shell.execute_reply.started":"2026-03-16T19:36:59.350004Z","shell.execute_reply":"2026-03-16T19:37:25.444819Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Loading TrOCR processor and model\ndevice = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\nprint(f\"Using device: {device}\")\n\nmodel_id = \"microsoft/trocr-base-printed\"\n\n# float16 inference for T$ runtime  \ndtype = torch.float16 if torch.cuda.is_available() else torch.float32\n\nprint(f\"Loading processor and model ({model_id}) in {dtype}...\")\nprocessor = TrOCRProcessor.from_pretrained(model_id)\nmodel = VisionEncoderDecoderModel.from_pretrained(model_id, torch_dtype=dtype)\nmodel.to(device)\nprint(\"Model loaded successfully!\")\n\n# Inference Function\ndef extract_text(image_source, is_url=True):\n    print(f\"Processing image: {image_source}\")\n    try:\n        if is_url:\n            response = requests.get(image_source, stream=True)\n            response.raise_for_status()\n            image = Image.open(BytesIO(response.content)).convert(\"RGB\")\n        else:\n            image = Image.open(image_source).convert(\"RGB\")\n        \n        # Preprocess\n        pixel_values = processor(image, return_tensors=\"pt\").pixel_values\n        pixel_values = pixel_values.to(device, dtype=dtype)\n        \n        # Generate text\n        start_time = time.time()\n\n        generated_ids = model.generate(pixel_values, max_length=64)\n        generated_text = processor.batch_decode(generated_ids, skip_special_tokens=True)[0]\n        elapsed = time.time() - start_time\n        \n        return generated_text, elapsed, image\n    except Exception as e:\n        print(f\"Error processing image: {e}\")\n        return None, 0, None","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-16T19:37:25.446957Z","iopub.execute_input":"2026-03-16T19:37:25.447411Z","iopub.status.idle":"2026-03-16T19:37:32.895905Z","shell.execute_reply.started":"2026-03-16T19:37:25.447381Z","shell.execute_reply":"2026-03-16T19:37:32.895058Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"sample_url = \"https://publicimageco.ca/wp-content/uploads/2020/03/PublicImageCo_HORIZ-scaled-1.png\"\n\ntext, generation_time, img = extract_text(sample_url, is_url=True)\n\nif text:\n    print(\"-\" * 50)\n    print(f\"Generation Time: {generation_time:.2f} seconds\")\n    print(f\"\\n=> Extracted Text : {text} <=\")\n    print(\"-\" * 50)\n    \n    # thumbnail\n    try:\n        from IPython.display import display\n        img.thumbnail((400, 400))\n        display(img)\n    except NameError:\n        pass","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-16T19:45:39.601728Z","iopub.execute_input":"2026-03-16T19:45:39.60207