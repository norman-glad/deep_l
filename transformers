   "source": [
    "# Loading TrOCR processor and model\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(f\"Using device: {device}\")\n",
    "\n",
    "model_id = \"microsoft/trocr-base-printed\"\n",
    "\n",
    "# float16 inference for T$ runtime  \n",
    "dtype = torch.float16 if torch.cuda.is_available() else torch.float32\n",
    "\n",
    "print(f\"Loading processor and model ({model_id}) in {dtype}...\")\n",
    "processor = TrOCRProcessor.from_pretrained(model_id)\n",
    "model = VisionEncoderDecoderModel.from_pretrained(model_id, torch_dtype=dtype)\n",
    "model.to(device)\n",
    "print(\"Model loaded successfully!\")\n",
    "\n",
    "# Inference Function\n",
    "def extract_text(image_source, is_url=True):\n",
    "    print(f\"Processing image: {image_source}\")\n",
    "    try:\n",
    "        if is_url:\n",
    "            response = requests.get(image_source, stream=True)\n",
    "            response.raise_for_status()\n",
    "            image = Image.open(BytesIO(response.content)).convert(\"RGB\")\n",
    "        else:\n",
    "            image = Image.open(image_source).convert(\"RGB\")\n",
    "        \n",
    "        # Preprocess\n",
    "        pixel_values = processor(image, return_tensors=\"pt\").pixel_values\n",
    "        pixel_values = pixel_values.to(device, dtype=dtype)\n",
    "        \n",
    "        # Generate text\n",
    "        start_time = time.time()\n",
    "\n",
    "        generated_ids = model.generate(pixel_values, max_length=64)\n",
    "        generated_text = processor.batch_decode(generated_ids, skip_special_tokens=True)[0]\n",
    "        elapsed = time.time() - start_time\n",
    "        \n",
    "        return generated_text, elapsed, image\n",
    "    except Exception as e:\n",
    "        print(f\"Error processing image: {e}\")\n",
    "        return None, 0, None"
   ]
  },
